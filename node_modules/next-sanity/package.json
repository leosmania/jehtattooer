{
  "name": "next-sanity",
  "version": "12.2.1",
  "description": "Sanity.io toolkit for Next.js",
  "keywords": [
    "live",
    "next.js",
    "preview",
    "sanity",
    "sanity.io",
    "studio",
    "studio-v3"
  ],
  "homepage": "https://github.com/sanity-io/next-sanity#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/next-sanity/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sanity-io/next-sanity.git",
    "directory": "packages/next-sanity"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "imports": {
    "#env": {
      "next-js": "./src/_env/next-js.ts",
      "react-server": "./src/_env/react-server.ts",
      "default": "./src/_env/default.ts"
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./draft-mode": "./dist/draft-mode/index.js",
    "./hooks": "./dist/hooks/index.js",
    "./image": "./dist/image/index.js",
    "./live": {
      "react-server": "./dist/live.js",
      "default": "./dist/live.server-only.js"
    },
    "./live/client-components/live": "./dist/live/client-components/live/index.js",
    "./live/client-components/live-stream": "./dist/live/client-components/live-stream/index.js",
    "./live/server-actions": "./dist/live/server-actions/index.js",
    "./studio": "./dist/studio/index.js",
    "./studio/client-component": "./dist/studio/client-component/index.js",
    "./visual-editing": "./dist/visual-editing/index.js",
    "./visual-editing/client-component": "./dist/visual-editing/client-component/index.js",
    "./visual-editing/server-actions": "./dist/visual-editing/server-actions/index.js",
    "./webhook": "./dist/webhook/index.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.3",
    "@sanity/client": "^7.20.0",
    "@sanity/comlink": "^4.0.1",
    "@sanity/presentation-comlink": "^2.0.1",
    "@sanity/preview-url-secret": "^4.0.4",
    "@sanity/visual-editing": "^5.3.3",
    "@sanity/webhook": "^4.0.4",
    "dequal": "^2.0.3",
    "groq": "^5.18.0",
    "history": "^5.3.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@sanity/tsconfig": "^2.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "js-yaml": "^4.1.1",
    "next": "16.2.1-canary.10",
    "publint": "^0.3.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.3.12",
    "tsdown": "0.20.3",
    "typedoc": "^0.28.17",
    "typescript": "5.9.3",
    "vitest": "^4.1.0",
    "vitest-package-exports": "^1.2.0"
  },
  "peerDependencies": {
    "@sanity/client": "^7.20.0",
    "next": "^16.0.0-0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sanity": "^5.18.0",
    "styled-components": "^6.1"
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "scripts": {
    "build": "tsdown --publint",
    "coverage": "npm test -- --coverage",
    "dev": "tsdown --watch",
    "test": "vitest",
    "docs:generate": "typedoc"
  }
}